# -----------------------------------------------------------------
# Pushpaka v1.0.0 - Environment Variables
# Copy this file to .env and fill in your values.
# -----------------------------------------------------------------

# -- Application --------------------------------------------------
APP_ENV=production           # development | production
LOG_LEVEL=info               # debug | info | warn | error

# -- Domain (for Traefik routing + Let's Encrypt) -----------------
DOMAIN=pushpaka.example.com          # Your base domain
ACME_EMAIL=admin@example.com         # Let's Encrypt registration email

# ----- Multi-Database Support ---------------------------------------
# Connection settings (DATABASE_DRIVER options: postgres, mysql, mssql, sqlite, mongodb)
# Note: sqlite ignores HOST/PORT/USER/PASSWORD and uses DB_NAME as the filepath
DATABASE_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=pushpaka
DB_PASSWORD=pushpaka
DB_NAME=pushpaka

# SSL/TLS Configuration for PostgreSQL
# Options: disable, prefer (development), require (production), verify-ca, verify-full
DB_SSL_MODE=disable
# Path to CA certificate file for database SSL connection
# Required when DB_SSL_MODE is set to require, verify-ca, or verify-full
# Example paths:
# - AWS RDS: /path/to/rds-ca-bundle.pem
# - Azure PostgreSQL: /path/to/DigiCertGlobalRootCA.crt
# - Self-signed: /etc/ssl/certs/postgres-ca.pem
DB_SSL_CERT_FILE=

# Connection pool tuning
# Adjust based on your workload (higher = more memory, but better concurrency)
DB_MAX_OPEN_CONNS=10        # Maximum open connections (default: 10 for dev, 30 for prod)
DB_MAX_IDLE_CONNS=3         # Maximum idle connections (default: 3 for dev, 10 for prod)
DB_CONN_MAX_LIFETIME=15m    # Connection lifetime before recycling

# ----- Redis Cache & Queue -------------------------------------------
# Redis is optional: leave empty to disable (uses in-memory queue in development)
# Required for multi-process deployments and production scaling
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=              # Leave empty if Redis has no password
REDIS_DB=0

# Redis connection pool tuning
# For development: smaller values are fine
# For production: tune based on expected concurrent job queue sizes
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=5           # Number of connections in the pool
REDIS_MIN_IDLE_CONNS=1      # Minimum idle connections to maintain
REDIS_MAX_CONN_AGE=10m      # Maximum connection lifespan
REDIS_POOL_TIMEOUT=4s       # Timeout for getting connection from pool
REDIS_IDLE_TIMEOUT=5m       # Timeout before idle connections are closed
REDIS_READ_TIMEOUT=3s       # Read operation timeout
REDIS_WRITE_TIMEOUT=3s      # Write operation timeout

# -- JWT ----------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRY_HOURS=24

# -- CORS (comma-separated for multiple origins) ------------------
CORS_ORIGINS=https://app.pushpaka.example.com


# ----- BUILD DIRECTORIES ---------------------------------------------------
# Temporary workspace for git clone and build operations
BUILDS_DIR=D:/tmp/builds/pushpaka
PROJECTS_DIR=D:/tmp/projects/pushpaka
# Permanent directory for in-place (no-Docker) deployments
DEPLOYS_DIR=D:/tmp/deploys/pushpaka
TESTS_DIR=D:/tmp/tests/pushpaka

# Number of concurrent build workers
BUILD_WORKERS=3
# AI worker to monitor in backend and create small alerts, health status, errors tips or recommendations
AI_WORKERS=2
# Git monitoring and syncing source code on every change to project code project folder along with commit id
SYNC_WORKERS=4
TEST_WORKER=2

# In Project source code how many last commit should be there and for each commit should be 1 build 
COMMIT_LIMIT=3 

# -- Component selection (unified binary) -------------------------
# Controls which subsystem(s) the pushpaka binary starts.
# all    (default) - API server + embedded build workers
# api              - API server only
# worker           - Build workers only (reads from Redis queue)
PUSHPAKA_COMPONENT=all

# -- Traefik Dashboard Auth ---------------------------------------
# Generate with: htpasswd -n admin
# Default below: admin / admin (CHANGE IN PRODUCTION)
TRAEFIK_AUTH=admin:$$apr1$$ruca84Hq$$mbjdMZBAG.KWn7XvjLOCl/

# -- GitHub OAuth (future - not yet active) -----------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
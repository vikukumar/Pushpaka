# -----------------------------------------------------------------
# Pushpaka v1.0.0 - Environment Variables
# Copy this file to .env and fill in your values.
# -----------------------------------------------------------------

# -- Application --------------------------------------------------
APP_ENV=production           # development | production
LOG_LEVEL=info               # debug | info | warn | error

# -- Domain (for Traefik routing + Let's Encrypt) -----------------
DOMAIN=pushpaka.example.com          # Your base domain
ACME_EMAIL=admin@example.com         # Let's Encrypt registration email

# -- PostgreSQL ---------------------------------------------------
POSTGRES_DB=pushpaka
POSTGRES_USER=pushpaka
POSTGRES_PASSWORD=change_this_strong_password

# -- Redis --------------------------------------------------------
REDIS_PASSWORD=change_this_redis_password

# -- JWT ----------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRY_HOURS=24

# -- CORS (comma-separated for multiple origins) ------------------
CORS_ORIGINS=https://app.pushpaka.example.com

# -- Build Workers ------------------------------------------------
# Number of concurrent build goroutines per worker process
BUILD_WORKERS=3

# -- Build Directories --------------------------------------------
# BUILD_CLONE_DIR: temp workspace where repos are git-cloned and built.
#   Default (Linux/macOS): /tmp/pushpaka-builds
#   Default (Windows):     %TEMP%\pushpaka-builds
BUILD_CLONE_DIR=/tmp/pushpaka-builds

# BUILD_DEPLOY_DIR: permanent directory for in-place (no-Docker) deployments.
#   Each project gets its own subdirectory here. Must be persistent storage.
#   Default (Linux/macOS): /deploy/pushpaka
#   Default (Windows):     %LOCALAPPDATA%\pushpaka\deploy
BUILD_DEPLOY_DIR=/deploy/pushpaka

# -- Component selection (unified binary) -------------------------
# Controls which subsystem(s) the pushpaka binary starts.
# all    (default) - API server + embedded build workers
# api              - API server only
# worker           - Build workers only (reads from Redis queue)
PUSHPAKA_COMPONENT=all

# -- Traefik Dashboard Auth ---------------------------------------
# Generate with: htpasswd -n admin
# Default below: admin / admin (CHANGE IN PRODUCTION)
TRAEFIK_AUTH=admin:$$apr1$$ruca84Hq$$mbjdMZBAG.KWn7XvjLOCl/

# -- GitHub OAuth (future - not yet active) -----------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
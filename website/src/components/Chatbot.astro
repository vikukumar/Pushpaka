---
// AI Chatbot Component for Pushpaka support

export interface Props {
  initialMessage?: string;
}

const { initialMessage = "Hi! I'm the Pushpaka assistant. How can I help you today?" } = Astro.props;
---

<div id="chatbot-container" class="fixed bottom-6 right-6 z-50 w-96 max-w-[calc(100vw-2rem)]">
  <!-- Chat Window -->
  <div id="chat-window" class="metallic-card rounded-lg shadow-2xl hidden flex flex-col h-96 max-h-screen">
    <!-- Header -->
    <div class="bg-gradient-to-r from-brand-600 to-accent-500 px-6 py-4 rounded-t-lg flex justify-between items-center">
      <h3 class="text-white font-bold text-lg">Pushpaka Assistant</h3>
      <button id="close-chat" class="text-white hover:text-gray-200 text-xl">×</button>
    </div>

    <!-- Messages -->
    <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-4 bg-surface-bg">
      <div class="flex gap-2">
        <div class="w-8 h-8 rounded-full bg-brand-600 flex items-center justify-center flex-shrink-0">
          <span class="text-white text-sm">🤖</span>
        </div>
        <div class="bg-surface-elevated rounded-lg px-4 py-2 text-gray-300 text-sm max-w-xs">
          { initialMessage }
        </div>
      </div>
    </div>

    <!-- Input -->
    <div class="border-t border-surface-border p-4 bg-surface-elevated rounded-b-lg">
      <div class="flex gap-2">
        <input
          id="chat-input"
          type="text"
          placeholder="Ask me about Pushpaka..."
          class="flex-1 bg-surface-bg border border-surface-border rounded px-3 py-2 text-white text-sm placeholder-gray-500 focus:outline-none focus:border-brand-500"
        />
        <button
          id="send-button"
          class="btn-primary text-sm px-4 py-2"
        >
          Send
        </button>
      </div>
    </div>
  </div>

  <!-- Toggle Button -->
  <button
    id="chatbot-toggle"
    class="bg-gradient-to-r from-brand-600 to-accent-500 text-white rounded-full w-14 h-14 flex items-center justify-center shadow-2xl hover:shadow-accent-glow transition-all"
  >
    <span class="text-2xl">💬</span>
  </button>
</div>

<style>
  #chatbot-container {
    --tw-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }
  
  #chat-messages::-webkit-scrollbar {
    width: 6px;
  }
  
  #chat-messages::-webkit-scrollbar-track {
    background: rgba(15, 23, 42, 0.5);
  }
  
  #chat-messages::-webkit-scrollbar-thumb {
    background: linear-gradient(to bottom, #6366f1, #06b6d4);
    border-radius: 3px;
  }

  @media (max-width: 480px) {
    #chatbot-container {
      max-width: calc(100vw - 1rem);
      bottom: 1rem;
      right: 0.5rem;
    }
    
    #chat-window {
      max-width: 100%;
      height: 70vh;
    }
  }
</style>

<script>
// System prompt for Pushpaka assistant
const SYSTEM_PROMPT = `You are a helpful assistant for Pushpaka, a self-hosted cloud deployment platform. 

You have knowledge about:
- Pushpaka features (Git deployments, auto-dockerization, rollbacks, monitoring)
- Installation on Linux, macOS, Windows, Docker, and Kubernetes
- Helm chart deployment
- API usage and REST endpoints
- Configuration and troubleshooting
- Release notes and changelog
- Best practices for production deployments

Always provide clear, concise answers. Include command examples when relevant.
If the user asks something unrelated to Pushpaka, politely redirect them.
Be friendly and helpful. If you don't know something, suggest checking the documentation.`;

const chatToggle = document.getElementById('chatbot-toggle');
const chatWindow = document.getElementById('chat-window');
const closeChat = document.getElementById('close-chat');
const chatInput = document.getElementById('chat-input');
const sendButton = document.getElementById('send-button');
const chatMessages = document.getElementById('chat-messages');

let isOpen = false;

if (!chatToggle || !chatWindow || !closeChat || !chatInput || !sendButton || !chatMessages) {
  console.warn('Chatbot UI was not initialized because one or more elements are missing.');
} else {

// Toggle chat window
chatToggle.addEventListener('click', () => {
  isOpen = !isOpen;
  if (isOpen) {
    chatWindow.classList.remove('hidden');
    chatToggle.classList.add('hidden');
    chatInput.focus();
  } else {
    chatWindow.classList.add('hidden');
    chatToggle.classList.remove('hidden');
  }
});

closeChat.addEventListener('click', () => {
  isOpen = false;
  chatWindow.classList.add('hidden');
  chatToggle.classList.remove('hidden');
});

// Send message
async function sendMessage() {
  const message = chatInput.value.trim();
  if (!message) return;

  // Add user message to chat
  const userMessageDiv = document.createElement('div');
  userMessageDiv.className = 'flex justify-end';
  userMessageDiv.innerHTML = `
    <div class="bg-brand-600 rounded-lg px-4 py-2 text-white text-sm max-w-xs">
      ${escapeHtml(message)}
    </div>
  `;
  chatMessages.appendChild(userMessageDiv);
  chatInput.value = '';
  chatMessages.scrollTop = chatMessages.scrollHeight;

  // Show loading indicator
  const loadingDiv = document.createElement('div');
  loadingDiv.className = 'flex gap-2';
  loadingDiv.innerHTML = `
    <div class="w-8 h-8 rounded-full bg-brand-600 flex items-center justify-center flex-shrink-0">
      <span class="text-white text-sm">🤖</span>
    </div>
    <div class="bg-surface-elevated rounded-lg px-4 py-2 text-gray-300 text-sm">
      <span class="animate-pulse">Thinking...</span>
    </div>
  `;
  chatMessages.appendChild(loadingDiv);
  chatMessages.scrollTop = chatMessages.scrollHeight;

  try {
    // Call OpenRouter API (via backend)
    const response = await fetch('/api/chat', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        message: message,
        systemPrompt: SYSTEM_PROMPT
      })
    });

    if (!response.ok) {
      throw new Error('Failed to get response');
    }

    const data = await response.json();
    loadingDiv.remove();

    // Add AI response
    const aiMessageDiv = document.createElement('div');
    aiMessageDiv.className = 'flex gap-2';
    aiMessageDiv.innerHTML = `
      <div class="w-8 h-8 rounded-full bg-brand-600 flex items-center justify-center flex-shrink-0 flex-shrink-0">
        <span class="text-white text-sm">🤖</span>
      </div>
      <div class="bg-surface-elevated rounded-lg px-4 py-2 text-gray-300 text-sm max-w-xs">
        ${escapeHtml(data.response)}
      </div>
    `;
    chatMessages.appendChild(aiMessageDiv);
  } catch (error) {
    loadingDiv.remove();
    const errorDiv = document.createElement('div');
    errorDiv.className = 'flex gap-2';
    errorDiv.innerHTML = `
      <div class="w-8 h-8 rounded-full bg-red-600 flex items-center justify-center flex-shrink-0">
        <span class="text-white text-sm">⚠️</span>
      </div>
      <div class="bg-red-950 rounded-lg px-4 py-2 text-red-200 text-sm max-w-xs">
        Sorry, I encountered an error. Please try again or check the documentation.
      </div>
    `;
    chatMessages.appendChild(errorDiv);
  }

  chatMessages.scrollTop = chatMessages.scrollHeight;
}

sendButton.addEventListener('click', sendMessage);
chatInput.addEventListener('keypress', (e) => {
  if (e.key === 'Enter') {
    sendMessage();
  }
});

// Utility to escape HTML
function escapeHtml(text) {
  const map = {
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#039;'
  };
  return text.replace(/[&<>"']/g, m => map[m]);
}
}
</script>

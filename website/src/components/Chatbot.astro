---
import { supportEntries, supportQuickPrompts } from '../data/support';

export interface Props {
  initialMessage?: string;
}

const {
  initialMessage = "Hi. I'm the Pushpaka support assistant. Ask about installation, AI monitoring, deployments, editor workflows, upgrades, or troubleshooting.",
} = Astro.props;

const publicChatApiUrl = import.meta.env.PUBLIC_CHAT_API_URL ?? '';
const base = import.meta.env.BASE_URL;
---

<div id="chatbot-container" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-4 pointer-events-none">
  <div id="chat-window" class="metallic-card rounded-2xl shadow-2xl hidden flex flex-col h-[34rem] w-[24rem] max-w-[calc(100vw-1rem)] max-h-[min(76vh,44rem)] pointer-events-auto overflow-hidden">
    <div class="bg-gradient-to-r from-brand-600 via-brand-500 to-accent-500 px-5 py-4 flex justify-between items-center">
      <div>
        <h3 class="text-white font-bold text-lg leading-tight">Pushpaka Support</h3>
        <p class="text-white/80 text-xs mt-1">AI-style product guidance for GitHub Pages</p>
      </div>
      <button id="close-chat" type="button" class="text-white hover:text-slate-100 text-2xl leading-none" aria-label="Close chat">×</button>
    </div>

    <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-4 bg-surface-bg">
      <div class="flex gap-3">
        <div class="w-9 h-9 rounded-full bg-brand-600 flex items-center justify-center flex-shrink-0 text-base text-white">AI</div>
        <div class="bg-surface-elevated rounded-2xl rounded-tl-sm px-4 py-3 text-gray-200 text-sm max-w-[18rem] shadow-lg shadow-black/10">
          {initialMessage}
        </div>
      </div>
    </div>

    <div class="border-t border-surface-border bg-surface-elevated p-4 space-y-3">
      <div id="quick-prompts" class="flex flex-wrap gap-2"></div>
      <div class="flex gap-2">
        <input
          id="chat-input"
          type="text"
          placeholder="Ask about install, AI logs, editor, upgrades..."
          class="flex-1 bg-surface-bg border border-surface-border rounded-xl px-3 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:border-brand-500"
        />
        <button id="send-button" type="button" class="btn-primary text-sm px-4 py-2.5">Send</button>
      </div>
      <div class="text-[11px] text-slate-400 leading-relaxed">
        Static-site assistant with built-in Pushpaka support knowledge.
        <a href={`${base}support`} class="text-brand-300 hover:text-brand-200">Open support hub</a>
      </div>
    </div>
  </div>

  <button
    id="chatbot-toggle"
    type="button"
    class="bg-gradient-to-br from-brand-600 via-brand-500 to-accent-500 text-white rounded-full w-16 h-16 flex items-center justify-center shadow-2xl transition-all pointer-events-auto border border-white/10"
    aria-label="Open Pushpaka support assistant"
  >
    <span class="text-2xl leading-none">💬</span>
  </button>
</div>

<style>
  #chatbot-container {
    --tw-shadow: 0 24px 70px rgba(2, 6, 23, 0.45);
  }

  #chatbot-toggle:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 24px 56px rgba(14, 165, 233, 0.28);
  }

  #chat-messages::-webkit-scrollbar {
    width: 6px;
  }

  #chat-messages::-webkit-scrollbar-track {
    background: rgba(15, 23, 42, 0.55);
  }

  #chat-messages::-webkit-scrollbar-thumb {
    background: linear-gradient(to bottom, #1d4ed8, #0ea5e9);
    border-radius: 999px;
  }

  @media (max-width: 640px) {
    #chatbot-container {
      bottom: 0.9rem;
      right: 0.9rem;
    }

    #chat-window {
      width: min(calc(100vw - 1.1rem), 24rem);
      height: min(72vh, 38rem);
    }
  }
</style>

<script define:vars={{ supportEntries, supportQuickPrompts, publicChatApiUrl, base }}>
  const chatToggle = document.getElementById('chatbot-toggle');
  const chatWindow = document.getElementById('chat-window');
  const closeChat = document.getElementById('close-chat');
  const chatInput = document.getElementById('chat-input');
  const sendButton = document.getElementById('send-button');
  const chatMessages = document.getElementById('chat-messages');
  const quickPrompts = document.getElementById('quick-prompts');

  let isOpen = false;

  const fallbackReply = {
    title: 'General Support',
    response:
      'I can help with installation, AI monitoring, AI log analysis, deployments, built-in editor workflows, domains, upgrades, and troubleshooting. If you want a guided path, open /support or /docs from the site navigation.',
    links: [
      { label: 'Support Hub', href: `${base}support` },
      { label: 'Documentation', href: `${base}docs` },
      { label: 'GitHub Repository', href: 'https://github.com/vikukumar/Pushpaka' },
    ],
  };

  function normalize(text) {
    return text.toLowerCase().replace(/[^a-z0-9\s/-]/g, ' ');
  }

  function scoreEntry(message, entry) {
    const normalizedMessage = normalize(message);
    return entry.keywords.reduce((score, keyword) => {
      const key = normalize(keyword);
      if (normalizedMessage.includes(key)) {
        return score + Math.max(3, key.split(' ').length * 2);
      }
      return score;
    }, 0);
  }

  function findSupportAnswer(message) {
    const ranked = supportEntries
      .map((entry) => ({ entry, score: scoreEntry(message, entry) }))
      .sort((left, right) => right.score - left.score);

    if (ranked[0] && ranked[0].score > 0) {
      return ranked[0].entry;
    }

    return fallbackReply;
  }

  async function queryPublicChatApi(message, answer) {
    if (!publicChatApiUrl) {
      return null;
    }

    try {
      const response = await fetch(publicChatApiUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          message,
          context: answer.response,
          source: 'pushpaka-website',
        }),
      });

      if (!response.ok) {
        return null;
      }

      const data = await response.json();
      if (typeof data?.response === 'string' && data.response.trim()) {
        return data.response.trim();
      }
    } catch (_error) {
      return null;
    }

    return null;
  }

  function escapeHtml(text) {
    const map = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;',
    };
    return text.replace(/[&<>"']/g, (char) => map[char]);
  }

  function renderLinks(links = []) {
    if (!links.length) {
      return '';
    }

    const rendered = links
      .map((link) => {
        const href = link.href.startsWith('http') ? link.href : link.href;
        const target = href.startsWith('http') ? ' target="_blank" rel="noopener noreferrer"' : '';
        return `<a href="${escapeHtml(href)}"${target} class="inline-flex items-center rounded-full border border-brand-400/30 bg-brand-500/10 px-2.5 py-1 text-[11px] font-medium text-brand-200 hover:bg-brand-500/20">${escapeHtml(link.label)}</a>`;
      })
      .join('');

    return `<div class="mt-3 flex flex-wrap gap-2">${rendered}</div>`;
  }

  function appendUserMessage(message) {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex justify-end';
    wrapper.innerHTML = `
      <div class="bg-brand-600 rounded-2xl rounded-tr-sm px-4 py-3 text-white text-sm max-w-[18rem] shadow-lg shadow-brand-950/20">
        ${escapeHtml(message)}
      </div>
    `;
    chatMessages.appendChild(wrapper);
  }

  function appendAssistantMessage(title, message, links = []) {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex gap-3';
    wrapper.innerHTML = `
      <div class="w-9 h-9 rounded-full bg-brand-600 flex items-center justify-center flex-shrink-0 text-xs font-semibold text-white">AI</div>
      <div class="bg-surface-elevated rounded-2xl rounded-tl-sm px-4 py-3 text-gray-200 text-sm max-w-[18rem] shadow-lg shadow-black/10">
        <div class="text-[11px] uppercase tracking-[0.18em] text-brand-300 mb-2">${escapeHtml(title)}</div>
        <div>${escapeHtml(message)}</div>
        ${renderLinks(links)}
      </div>
    `;
    chatMessages.appendChild(wrapper);
  }

  function appendLoading() {
    const loading = document.createElement('div');
    loading.className = 'flex gap-3';
    loading.innerHTML = `
      <div class="w-9 h-9 rounded-full bg-brand-600 flex items-center justify-center flex-shrink-0 text-xs font-semibold text-white">AI</div>
      <div class="bg-surface-elevated rounded-2xl rounded-tl-sm px-4 py-3 text-gray-300 text-sm">
        Finding the right Pushpaka answer...
      </div>
    `;
    chatMessages.appendChild(loading);
    return loading;
  }

  function scrollMessages() {
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  async function sendMessage(message) {
    const trimmed = (message ?? chatInput.value).trim();
    if (!trimmed) {
      return;
    }

    appendUserMessage(trimmed);
    chatInput.value = '';
    scrollMessages();

    const loading = appendLoading();
    scrollMessages();

    const supportAnswer = findSupportAnswer(trimmed);
    const externalResponse = await queryPublicChatApi(trimmed, supportAnswer);
    loading.remove();

    appendAssistantMessage(
      supportAnswer.title,
      externalResponse || supportAnswer.response,
      supportAnswer.links,
    );
    scrollMessages();
  }

  function openChat() {
    isOpen = true;
    chatWindow.classList.remove('hidden');
    chatToggle.classList.add('hidden');
    chatInput.focus();
  }

  function closeChatWindow() {
    isOpen = false;
    chatWindow.classList.add('hidden');
    chatToggle.classList.remove('hidden');
  }

  function initQuickPrompts() {
    supportQuickPrompts.forEach((prompt) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'rounded-full border border-surface-border bg-surface-bg px-3 py-1.5 text-[11px] font-medium text-slate-300 hover:border-brand-400/40 hover:text-brand-200';
      button.textContent = prompt;
      button.addEventListener('click', () => sendMessage(prompt));
      quickPrompts.appendChild(button);
    });
  }

  if (!chatToggle || !chatWindow || !closeChat || !chatInput || !sendButton || !chatMessages || !quickPrompts) {
    console.warn('Chatbot UI was not initialized because one or more elements are missing.');
  } else {
    initQuickPrompts();

    chatToggle.addEventListener('click', openChat);
    closeChat.addEventListener('click', closeChatWindow);
    sendButton.addEventListener('click', () => sendMessage());
    chatInput.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        sendMessage();
      }
    });
  }
</script>

---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Pushpaka - Carry your code to the cloud effortlessly" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#6366f1" />
    <link rel="icon" type="image/svg+xml" href="/Pushpaka/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-surface-bg text-gray-100 antialiased">
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  body {
    background: linear-gradient(to bottom, #0f172a 0%, #1a1f3a 50%, #0f172a 100%);
  }

  @supports (backdrop-filter: blur(1px)) {
    .glass {
      background: rgba(30, 41, 59, 0.8);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(148, 163, 184, 0.1);
    }
  }
</style>

---
import '../styles/global.css';
import Chatbot from '../components/Chatbot.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
}

const base = import.meta.env.BASE_URL;
const {
  title,
  description = "Pushpaka is an AI-native self-hosted multi-platform deployment platform with Git-based delivery, monitoring, log analysis, built-in editor workflows, and real-time infrastructure control.",
  keywords = "Pushpaka, self-hosted deployment platform, AI deployment monitoring, AI log analysis, multi-platform deployment, GitOps platform, Docker deployment, Kubernetes deployment, built-in code editor, web terminal, Traefik platform",
  image = `${base}og-image.png`,
} = Astro.props;

const site = Astro.site ?? new URL('https://pushpaka.vikshro.in/');
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL(image, site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Pushpaka',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Linux, macOS, Windows, Docker, Kubernetes',
  description,
  url: canonical,
  image: ogImage,
  softwareVersion: '1.0.0',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  creator: {
    '@type': 'Organization',
    name: 'Pushpaka',
  },
  featureList: [
    'AI deployment monitoring',
    'AI log analysis',
    'Git-based multi-platform deployment',
    'Built-in code editor',
    'Web terminal',
    'Docker and Kubernetes infrastructure controls',
    'Traefik routing and TLS',
  ],
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Pushpaka" />
    <meta name="application-name" content="Pushpaka" />
    <meta name="theme-color" content="#6366f1" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Pushpaka" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Pushpaka - AI-native self-hosted deployment platform" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Pushpaka - AI-native self-hosted deployment platform" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <title>{title}</title>
  </head>
  <body class="text-gray-100 antialiased">
    <slot />
    <Chatbot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
  }
</style>

<script>
  const revealTargets = [
    'main section',
    'section',
    '.metallic-card',
    '.section-title',
    '.section-subtitle',
    '.code-block',
    'table',
    'footer',
  ];

  const applyRevealAttributes = () => {
    const seen = new Set();
    let index = 0;

    revealTargets.forEach((selector) => {
      document.querySelectorAll(selector).forEach((element) => {
        if (seen.has(element) || element.closest('#chatbot-container')) {
          return;
        }
        seen.add(element);
        if (!element.hasAttribute('data-reveal')) {
          element.setAttribute('data-reveal', '');
          element.style.setProperty('--reveal-delay', `${Math.min(index * 70, 420)}ms`);
          index += 1;
        }
      });
    });
  };

  const setupRevealObserver = () => {
    const elements = document.querySelectorAll('[data-reveal]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        } else {
          entry.target.classList.remove('is-visible');
        }
      });
    }, {
      threshold: 0.14,
      rootMargin: '0px 0px -8% 0px',
    });

    elements.forEach((element) => observer.observe(element));
  };

  const initSiteEffects = () => {
    applyRevealAttributes();
    setupRevealObserver();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSiteEffects, { once: true });
  } else {
    initSiteEffects();
  }
</script>

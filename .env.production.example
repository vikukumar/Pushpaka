# ========================================================================
# Pushpaka v1.0.0 - Production Environment Variables
# Copy this file to .env and fill in your values for production deployment
# ========================================================================

# ----- APPLICATION ---------------------------------------------------------
APP_ENV=production              # production
LOG_LEVEL=warn                  # debug | info | warn | error
PORT=8080
BASE_URL=https://pushpaka.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com

# ----- POSTGRESQL (Production-Grade) -----------------------------------------
# PostgreSQL with SSL/TLS encryption enabled
DB_HOST=your-postgres-host.example.com
DB_PORT=5432
DB_USER=pushpaka_prod
DB_PASSWORD=your_strong_password_here_min_32_chars
DB_NAME=pushpaka_prod

# SSl/TLS Configuration
# ssl_mode options: disable, require, verify-ca, verify-full
# For production, use "require" (enforce encryption) or "verify-full" (validate hostname)
DB_SSL_MODE=require
# Path to CA certificate file for database SSL connection
# If using AWS RDS, download: https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/UsingWithRDS.html
# If using Azure Database for PostgreSQL, download: https://learn.microsoft.com/en-us/azure/postgresql/
DB_SSL_CERT_FILE=/etc/ssl/certs/postgres-ca.pem

# Connection pool tuning for production
DB_MAX_OPEN_CONNS=30
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# ----- REDIS (Production-Grade) -----------------------------------------------
# Redis with optional authentication
REDIS_HOST=your-redis-host.example.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# Redis connection pool settings
REDIS_MAX_RETRIES=5
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_MAX_CONN_AGE=10m
REDIS_POOL_TIMEOUT=4s
REDIS_IDLE_TIMEOUT=5m
REDIS_READ_TIMEOUT=5s
REDIS_WRITE_TIMEOUT=5s

# ----- JWT & SECURITY -------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=generate_a_random_secret_with_openssl_rand_hex_32
JWT_EXPIRY_HOURS=24

# ----- DOMAIN & SSL (Traefik) ------------------------------------------------
DOMAIN=pushpaka.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# ----- BUILD DIRECTORIES ---------------------------------------------------
# Temporary workspace for git clone and build operations
BUILD_CLONE_DIR=/tmp/pushpaka-builds

# Permanent directory for in-place (no-Docker) deployments
BUILD_DEPLOY_DIR=/deploy/pushpaka

# Number of concurrent build workers
BUILD_WORKERS=3

# ----- OAUTH PROVIDERS (GitHub) -----------------------------------------------
GITHUB_CLIENT_ID=your_github_oauth_app_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_secret

# ----- OAUTH PROVIDERS (GitLab) -----------------------------------------------
GITLAB_CLIENT_ID=your_gitlab_oauth_app_id
GITLAB_CLIENT_SECRET=your_gitlab_oauth_app_secret
GITLAB_BASE_URL=https://gitlab.com  # or your self-hosted GitLab URL

# ----- AI Integration (Optional) -----------------------------------------------
# Supported providers: openai, openrouter, gemini, anthropic, ollama
AI_PROVIDER=openai
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o-mini
AI_BASE_URL=  # Leave empty for default, or set to custom endpoint
AI_RATE_LIMIT_PER_USER_PER_DAY=10  # 0 = unlimited

# ----- NOTIFICATIONS (SMTP) --------------------------------------------------
SMTP_HOST=smtp.gmail.com          # or your email provider
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@yourdomain.com

# ----- DOCKER CONFIGURATION --------------------------------------------------
# For remote Docker daemon (optional)
DOCKER_HOST=unix:///var/run/docker.sock

# Traefik network name (for container networking)
TRAEFIK_NETWORK=pushpaka-network

# ----- COMPONENT SELECTION --------------------------------------------------
# all    = API + embedded workers in one process
# api    = API only (requires separate worker processes)
# worker = Worker only (reads from Redis queue)
PUSHPAKA_COMPONENT=all

# ----- DATABASE DRIVER SELECTION (Development Only) -----------------------------------------------
# For production, always use: postgres
DATABASE_DRIVER=postgres
# For production, leave DATABASE_URL empty and use DB_* variables above
# DATABASE_URL is ignored when DATABASE_DRIVER=postgres and DB_* vars are set
DATABASE_URL=
